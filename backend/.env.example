# ── SISA Backend Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to version control.

# ── Claude AI (required for real AI insights) ───────────────────────────────
# Obtain from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# ── API authentication ───────────────────────────────────────────────────────
# Protect every analysis endpoint with a static bearer key.
# Leave empty to disable auth (dev / Docker Compose default).
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sisa:sisa_password@localhost:5432/sisa_db

# ── Redis cache ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production set this to your actual frontend URL, e.g.: https://app.example.com
ALLOWED_ORIGINS=http://localhost:5173

# ── File upload size limit ─────────────────────────────────────────────────── 
# Maximum bytes accepted for /analyze/file (default: 10 485 760 = 10 MB).
MAX_FILE_BYTES=10485760
